# Source account — read access to raw log bucket
SOURCE_AWS_ACCESS_KEY_ID=
SOURCE_AWS_SECRET_ACCESS_KEY=
SOURCE_BUCKET=raw-resolution-logs.datacite.org
SOURCE_PREFIX=202604/

# Destination account — read/write access to staging and processed buckets
DEST_AWS_ACCESS_KEY_ID=
DEST_AWS_SECRET_ACCESS_KEY=
DEST_BUCKET=datacite-logs
PROCESSED_BUCKET=datacite-logs-processed

# Fargate / ECS (used by chunk_and_process.py)
ECS_CLUSTER=datacite-logs
ECS_TASK_DEF=datacite-log-processor
ECS_SUBNET=subnet-0e817dccd6519b354
AWS_REGION=us-east-2
